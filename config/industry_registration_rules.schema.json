{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seoulmna.co.kr/schemas/industry_registration_rules.schema.json",
  "title": "Industry Registration Rules",
  "type": "object",
  "required": ["version", "industries", "cost_rules"],
  "properties": {
    "version": {"type": "string"},
    "effective_date": {"type": "string", "format": "date"},
    "industries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "name", "requirements"],
        "properties": {
          "code": {"type": "string"},
          "name": {"type": "string"},
          "category": {"type": "string"},
          "requirements": {
            "type": "object",
            "properties": {
              "capital_eok": {"type": "number"},
              "guarantee_jwasu": {"type": "number"},
              "guarantee_deposit_eok": {"type": "number"},
              "engineers": {"type": "integer"},
              "facility": {"type": "array", "items": {"type": "string"}}
            }
          },
          "special_rules": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["rule_id", "kind"],
              "properties": {
                "rule_id": {"type": "string"},
                "kind": {"type": "string", "enum": ["capital_credit", "engineer_credit", "major_field_exception", "region_override", "other"]},
                "params": {"type": "object"},
                "priority": {"type": "integer", "minimum": 1, "maximum": 100}
              }
            }
          }
        }
      }
    },
    "cost_rules": {
      "type": "object",
      "properties": {
        "registration_tax": {"type": "object"},
        "local_tax": {"type": "object"},
        "bond": {"type": "object"},
        "diagnosis": {"type": "object"},
        "professional_fee": {"type": "object"}
      }
    },
    "region_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["rule_id", "match", "result"],
        "properties": {
          "rule_id": {"type": "string"},
          "match": {"type": "object"},
          "result": {"type": "object"},
          "priority": {"type": "integer"}
        }
      }
    }
  }
}
