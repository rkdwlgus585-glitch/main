# seoulmna.kr Platform Front — Environment Variables
# Copy this file to .env.local and update values as needed.

# Platform & content hosts
NEXT_PUBLIC_PLATFORM_FRONT_HOST=https://seoulmna.kr
NEXT_PUBLIC_LISTING_HOST=https://seoulmna.co.kr
NEXT_PUBLIC_CONTENT_HOST=https://seoulmna.co.kr

# Calculator engine
NEXT_PUBLIC_CALCULATOR_MOUNT_BASE=https://seoulmna.kr/_calc
NEXT_PUBLIC_PRIVATE_ENGINE_ORIGIN=https://calc.seoulmna.co.kr

# Server-side only: backend engine origin for Vercel rewrites
# (/_calc/* paths are proxied to this origin)
ENGINE_ORIGIN=https://calc.seoulmna.co.kr

# Server-side only: API Route proxy targets (native React calculator)
# These point to the Python AI engine backends.
# Local dev: http://127.0.0.1:8200 / http://127.0.0.1:8100
# Production: through nginx at https://seoulmna.kr/_calc/yangdo and /_calc/permit
YANGDO_ENGINE_ORIGIN=http://127.0.0.1:8200
YANGDO_BLACKBOX_API_KEY=
PERMIT_ENGINE_ORIGIN=http://127.0.0.1:8100
PERMIT_API_KEY=

# Consult API proxy target (server-side only)
CONSULT_API_ORIGIN=http://127.0.0.1:8788

# Native React calculator toggle (set to "true" to use React components instead of iframe)
NEXT_PUBLIC_NATIVE_CALC=true

# Toss Payments billing
NEXT_PUBLIC_TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
TOSS_WEBHOOK_SECRET=
CRON_SECRET=

# Contact info
NEXT_PUBLIC_CONTACT_PHONE=1668-3548
NEXT_PUBLIC_CONTACT_EMAIL=seoulmna@gmail.com

# Multi-tenant
NEXT_PUBLIC_TENANT_ID=seoul_main
