# ==========================================
# SeoulMNA automation environment template
# Copy to `.env` and fill real values.
# ==========================================

# Core listing pipeline
JSON_FILE=all_upload_state.json
SHEET_NAME=26양도매물
# Listing board target only (.co.kr). Do not point to seoulmna.kr.
SITE_URL=https://seoulmna.co.kr
MNA_BOARD_SLUG=mna
ADMIN_ID=
ADMIN_PW=

# Google Sheet auth
GSHEET_JSON_FILE=service_account.json
# GSHEET_JSON_BASE64=

# Notice/blog CTA
KAKAO_OPENCHAT_URL=https://open.kakao.com/o/syWr1hIe

# WordPress (blog automation)
# Blog WordPress target only (.kr). Must not use seoulmna.co.kr here.
WP_URL=
WP_USER=
WP_PASSWORD=

# Gabji generation
GABJI_LIVE_ENRICH=0

# Tistory automation (isolated in tistory_ops/)
TISTORY_ACCESS_TOKEN=
TISTORY_BLOG_NAME=seoulmna
TISTORY_DEFAULT_CATEGORY_ID=
TISTORY_DEFAULT_VISIBILITY=3
TISTORY_DEFAULT_TAGS=서울건설정보,건설양도양수
TISTORY_API_BASE=https://www.tistory.com/apis
TISTORY_OAUTH_BASE=https://www.tistory.com/oauth
TISTORY_APP_ID=
TISTORY_APP_SECRET=
TISTORY_REDIRECT_URI=
TISTORY_BLOG_DOMAIN=seoulmna.tistory.com
TISTORY_LOGIN_URL=https://www.tistory.com/auth/login
TISTORY_LOGIN_ID=
TISTORY_LOGIN_PASSWORD=
TISTORY_AUTO_LOGIN=0
TISTORY_ALLOWED_BLOG_DOMAINS=seoulmna.tistory.com
TISTORY_CHROME_DEBUGGER=
TISTORY_CHROME_USER_DATA_DIR=
TISTORY_CHROME_PROFILE_DIR=Default
TISTORY_PAGE_TIMEOUT_SEC=30
TISTORY_PUBLISH_DELAY_SEC=0.6
TISTORY_AUTO_IMAGES=1
TISTORY_IMAGE_COUNT=2
TISTORY_SEO_MIN_SCORE=90
TISTORY_DAILY_START_REG=7540
TISTORY_DAILY_STATE_FILE=logs/tistory_daily_state.json
TISTORY_DAILY_TIMEZONE_OFFSET=+09:00
TISTORY_DAILY_SKIP_IF_POSTED_TODAY=1

# AI providers (optional)
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
