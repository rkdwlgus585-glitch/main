{
  "$schema": "./contract.schema.json",
  "automation": "maemul",
  "description": "Maemul listing collection automation.",
  "checks": [
    {
      "id": "entry_files_exist",
      "type": "file_exists",
      "paths": [
        "../ALL/maemul.py"
      ]
    },
    {
      "id": "compile_maemul",
      "type": "python_compile",
      "paths": [
        "../ALL/maemul.py"
      ]
    },
    {
      "id": "import_maemul",
      "type": "python_import",
      "modules": [
        "maemul"
      ],
      "timeout_sec": 20
    },
    {
      "id": "cli_help",
      "type": "command",
      "command": [
        "{python}",
        "../ALL/maemul.py",
        "--help"
      ],
      "timeout_sec": 20
    }
  ]
}
