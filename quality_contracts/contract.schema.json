{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "quality_contracts/contract.schema.json",
  "title": "Automation Quality Contract",
  "type": "object",
  "required": [
    "automation",
    "checks"
  ],
  "properties": {
    "automation": {
      "type": "string",
      "pattern": "^[a-z0-9_\\-]+$"
    },
    "description": {
      "type": "string"
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/check"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "check": {
      "type": "object",
      "required": [
        "id",
        "type"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "file_exists",
            "python_compile",
            "python_import",
            "unittest_discover",
            "command",
            "json_report"
          ]
        },
        "required": {
          "type": "boolean",
          "default": true
        },
        "timeout_sec": {
          "type": "number",
          "minimum": 1
        },
        "paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "modules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "start_dir": {
          "type": "string"
        },
        "pattern": {
          "type": "string"
        },
        "command": {
          "oneOf": [
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            {
              "type": "string"
            }
          ]
        },
        "shell": {
          "type": "boolean"
        },
        "glob": {
          "type": "string"
        },
        "max_age_hours": {
          "type": "number",
          "minimum": 0
        },
        "must_have_keys": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    }
  }
}
