{
  "$schema": "./contract.schema.json",
  "automation": "quote_engine",
  "description": "Quote generation automation.",
  "checks": [
    {
      "id": "entry_files_exist",
      "type": "file_exists",
      "paths": [
        "quote_engine.py"
      ]
    },
    {
      "id": "compile_quote_engine",
      "type": "python_compile",
      "paths": [
        "quote_engine.py"
      ]
    },
    {
      "id": "import_quote_engine",
      "type": "python_import",
      "modules": [
        "quote_engine"
      ],
      "timeout_sec": 20
    },
    {
      "id": "cli_help",
      "type": "command",
      "command": [
        "{python}",
        "quote_engine.py",
        "--help"
      ],
      "timeout_sec": 20
    }
  ]
}
